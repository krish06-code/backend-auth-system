<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        <div class="flex justify-end w-full">
            <a href="/logout" class="bg-red-500 px-3 py-2 inline-block mb-5 rounded-md text-sm">logout</a>

        </div>
        <h3 class="text-3xl "> <span class="font-light">Hello</span>, <%= user.name %>  </h3>
        <h5 class="mb-5">you can create some posts</h5>
        <form method="post" action="/post">
            <textarea name="content" placeholder="What's on your mind?" class=" block p-3 outline-none bg-transparent w-1/3 border-2 border-zinc-800 rounded-md resize-none"></textarea>
            <input type="submit" class=" block w-40 mt-3 text-sm px-3 py-2 bg-blue-500 rounded-md" value="Create post">
        </form>

        <div class="posts mt-20">
            <h3 class="text-zinc-400 text-2xl">Your posts</h3>
            <div class="PostContainer flex gap-5 flex-wrap mt-5">
               <% user.posts.reverse().forEach(function(post){ %> 
                <!-- reverse is used for the latest one on the top it prints the posts in reverse order -->
                 <div class="post w-1/3 mb-4 rounded-md bg-zinc-800 border-[1px] border-zinc-800 p-3">
                    <h4 class="text-blue-500 mb-2">@<%=user.username%></h4>
                    <p class="text-sm tracking-tight"><%= post.content%></p>
                    <small class="inline-block mt-3"><%= post.likes.length %> likes</small>
                    <div class="btns flex mt-1 gap-4">
                        <a class="text-blue-500" href="/like/<%= post._id %>"><%= post.likes.indexOf(user._id) ===-1?"Like":"Unlike" %> </a>
                        <a class="text-zinc-400" href="/edit/<%= post._id%>">edit</a>
                    </div>
                </div> 
              <% }) %>
                
            </div>
        </div>
    </div>
</body>
</html>