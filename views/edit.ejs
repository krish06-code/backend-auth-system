<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
      <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 text-white p-10">
        
        <h5 class="mb-5">Edit your Post</h5>
        <form method="post" action="/update/<%=post._id%>">
            <textarea name="content" placeholder="What's on your mind?" class=" block p-3 outline-none bg-transparent w-1/3 border-2 border-zinc-800 rounded-md resize-none"><%=post.content%></textarea>
            <input type="submit" class=" block w-40 mt-3 text-sm px-3 py-2 bg-yellow-500 text-black rounded-md" value="Update post">
        </form>

        
    </div>
</body>
</html>